---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Infergence Limited - Architecting Scalable Data Foundations for the AI Era." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Infergence</title>
  </head>
  <body>
    <!-- Transparent / Absolute Header -->
    <header>
      <div class="container header-inner">
        <a href="/" class="logo">infergence.</a>
        <nav class="nav-links">
          <a href="/services">Services</a>
          <a href="/solutions">Solutions</a>
          <a href="/case-studies">Case studies</a>
        </nav>
        <a href="mailto:contact@infergence.com" class="btn btn-primary">Let's talk</a>
      </div>
    </header>
    
    <main>
      <slot />
    </main>

    <footer class="bg-dark" style="padding: 6rem 0; text-align: left; margin-top: 0;">
      <div class="container" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 4rem;">
        <div>
          <a href="/" class="logo" style="margin-bottom: 2rem; display: inline-flex;">infergence.</a>
          <p style="color: var(--text-muted); font-size: 0.9rem;">Architecting scalable data foundations and AI solutions.</p>
        </div>
        <div>
          <h4 style="margin-bottom: 1.5rem;">Services</h4>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.8rem; color: var(--text-muted); font-size: 0.9rem;">
            <li><a href="/services">Data Engineering</a></li>
            <li><a href="/services">Generative AI</a></li>
            <li><a href="/services">Cloud Migrations</a></li>
          </ul>
        </div>
        <div>
          <h4 style="margin-bottom: 1.5rem;">Company</h4>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.8rem; color: var(--text-muted); font-size: 0.9rem;">
            <li><a href="/case-studies">Case studies</a></li>
            <li><a href="/blog">Blog</a></li>
          </ul>
        </div>
        <div>
          <h4 style="margin-bottom: 1.5rem;">Contact</h4>
          <p style="color: var(--text-muted); font-size: 0.9rem;">contact@infergence.com</p>
        </div>
      </div>
      <div class="container" style="text-align: center; margin-top: 4rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.1); color: var(--text-muted); font-size: 0.8rem;">
        <p>&copy; {new Date().getFullYear()} Infergence Limited. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
